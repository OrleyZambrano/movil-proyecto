{
	"info": {
		"name": "Reporte Ciudadano API",
		"description": "Colección completa de endpoints para el Sistema de Reporte Ciudadano.\n\nBase URL: http://192.168.100.38:8000/api\n\n## Autenticación\n- La mayoría de endpoints requieren token Bearer.\n- El token se obtiene al hacer login o register.\n- La colección guarda automáticamente el token en la variable {{token}}.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://192.168.100.38:8000/api" },
		{ "key": "token", "value": "" },
		{ "key": "reporte_id", "value": "1" },
		{ "key": "categoria_id", "value": "1" },
		{ "key": "comentario_id", "value": "1" },
		{ "key": "notificacion_id", "value": "1" }
	],
	"item": [
		{
			"name": "Auth",
			"description": "Endpoints de autenticación: registro, inicio de sesión, cierre de sesión y obtener usuario actual.",
			"item": [
				{
					"name": "Registrar usuario",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    console.log('Token guardado:', json.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Juan Pérez\",\n    \"email\": \"juan@ejemplo.com\",\n    \"password\": \"123456\",\n    \"password_confirmation\": \"123456\",\n    \"telefono\": \"5551234567\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": ["{{base_url}}"],
							"path": ["register"]
						}
					}
				},
				{
					"name": "Iniciar sesión",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    console.log('Token guardado:', json.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"ciudadano@reportes.com\",\n    \"password\": \"ciudadano123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					}
				},
				{
					"name": "Obtener usuario autenticado",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/user",
							"host": ["{{base_url}}"],
							"path": ["user"]
						}
					}
				},
				{
					"name": "Cerrar sesión",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						}
					}
				}
			]
		},
		{
			"name": "Categorías",
			"description": "Endpoints públicos y privados para gestionar categorías de reportes.",
			"item": [
				{
					"name": "Listar categorías (público)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/categorias",
							"host": ["{{base_url}}"],
							"path": ["categorias"]
						}
					}
				},
				{
					"name": "Crear categoría (admin)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"Señalización dañada\",\n    \"icono\": \"signpost\",\n    \"color\": \"#f43f5e\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/categorias",
							"host": ["{{base_url}}"],
							"path": ["categorias"]
						}
					}
				},
				{
					"name": "Actualizar categoría (admin)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"Señalización dañada\",\n    \"icono\": \"signpost\",\n    \"color\": \"#e11d48\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/categorias/{{categoria_id}}",
							"host": ["{{base_url}}"],
							"path": ["categorias", "{{categoria_id}}"]
						}
					}
				},
				{
					"name": "Eliminar categoría (admin)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/categorias/{{categoria_id}}",
							"host": ["{{base_url}}"],
							"path": ["categorias", "{{categoria_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "Reportes",
			"description": "Endpoints para gestionar reportes ciudadanos. Los GET son públicos; POST, PUT, PATCH y DELETE requieren autenticación.",
			"item": [
				{
					"name": "Listar reportes (público)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/reportes",
							"host": ["{{base_url}}"],
							"path": ["reportes"],
							"query": [
								{ "key": "categoria_id", "value": "1", "description": "Filtrar por categoría (opcional)" },
								{ "key": "estado", "value": "pendiente", "description": "Filtrar por estado (opcional)" }
							]
						}
					}
				},
				{
					"name": "Crear reporte (ciudadano)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "categoria_id", "value": "1", "type": "text" },
								{ "key": "titulo", "value": "Bache en Av. Principal", "type": "text" },
								{ "key": "descripcion", "value": "Hay un bache muy grande que daña los vehículos.", "type": "text" },
								{ "key": "latitud", "value": "19.432608", "type": "text" },
								{ "key": "longitud", "value": "-99.133209", "type": "text" },
								{ "key": "direccion", "value": "Av. Principal esq. Calle 5, Col. Centro", "type": "text" },
								{ "key": "prioridad", "value": "4", "type": "text" },
								{ "key": "fotografia", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{base_url}}/reportes",
							"host": ["{{base_url}}"],
							"path": ["reportes"]
						}
					}
				},
				{
					"name": "Ver detalle de reporte (público)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('reporte_id', json.data.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/reportes/{{reporte_id}}",
							"host": ["{{base_url}}"],
							"path": ["reportes", "{{reporte_id}}"]
						}
					}
				},
				{
					"name": "Editar reporte (ciudadano - solo pendiente)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"titulo\": \"Bache en Av. Principal (actualizado)\",\n    \"descripcion\": \"El bache ha crecido, necesita atención urgente.\",\n    \"prioridad\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/reportes/{{reporte_id}}",
							"host": ["{{base_url}}"],
							"path": ["reportes", "{{reporte_id}}"]
						}
					}
				},
				{
					"name": "Cambiar estado (funcionario/admin)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"estado\": \"en_revision\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/reportes/{{reporte_id}}/estado",
							"host": ["{{base_url}}"],
							"path": ["reportes", "{{reporte_id}}", "estado"]
						}
					}
				},
				{
					"name": "Mis reportes (ciudadano)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/mis-reportes",
							"host": ["{{base_url}}"],
							"path": ["mis-reportes"]
						}
					}
				},
				{
					"name": "Eliminar reporte (admin)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/reportes/{{reporte_id}}",
							"host": ["{{base_url}}"],
							"path": ["reportes", "{{reporte_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "Comentarios",
			"description": "Endpoints para comentarios en reportes. Solo funcionarios y administradores pueden crear comentarios.",
			"item": [
				{
					"name": "Ver comentarios de reporte (público)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/reportes/{{reporte_id}}/comentarios",
							"host": ["{{base_url}}"],
							"path": ["reportes", "{{reporte_id}}", "comentarios"]
						}
					}
				},
				{
					"name": "Agregar comentario (funcionario/admin)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"comentario\": \"Hemos recibido su reporte. Un equipo acudirá a revisar el bache en las próximas 48 horas.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/reportes/{{reporte_id}}/comentarios",
							"host": ["{{base_url}}"],
							"path": ["reportes", "{{reporte_id}}", "comentarios"]
						}
					}
				}
			]
		},
		{
			"name": "Notificaciones",
			"description": "Endpoints para gestionar notificaciones del usuario autenticado.",
			"item": [
				{
					"name": "Listar notificaciones",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/notificaciones",
							"host": ["{{base_url}}"],
							"path": ["notificaciones"]
						}
					}
				},
				{
					"name": "Marcar notificación como leída",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/notificaciones/{{notificacion_id}}/leida",
							"host": ["{{base_url}}"],
							"path": ["notificaciones", "{{notificacion_id}}", "leida"]
						}
					}
				}
			]
		},
		{
			"name": "Estadísticas",
			"description": "Estadísticas del sistema. Solo administradores.",
			"item": [
				{
					"name": "Ver estadísticas (admin)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json", "type": "text" },
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/estadisticas",
							"host": ["{{base_url}}"],
							"path": ["estadisticas"]
						}
					}
				}
			]
		}
	]
}
